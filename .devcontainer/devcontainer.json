{
  "name": "Fullstack Dev Container",
  "image": "mcr.microsoft.com/devcontainers/dotnet:10.0",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "postCreateCommand": "dotnet restore SaaS-Factory.slnx",
  "remoteUser": "vscode",
  "forwardPorts": [
    18889, // .NET Aspire dashboard
    9000, // AppGateway (YARP)
    9100, // ApiService
    9200, // Web (Blazor)
    5432 // PostgreSQL (Aspire-managed container)
  ],
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.10"
    }
  },
  "runArgs": [
    "--init"
  ], // Additional Docker run arguments if needed
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "editor.fontSize": 14,
        "editor.cursorBlinking": "solid",
        "python.pythonPath": "/usr/bin/python3",
        "editor.formatOnSave": true,
        "typescript.tsdk": "node_modules/typescript/lib",
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "msjsdiag.debugger-for-chrome",
        "esbenp.prettier-vscode",
        "GitHub.codespaces",
        "ms-dotnettools.csharp",
        "ms-python.python",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "ms-vscode.vscode-typescript-tslint-plugin",
        "Postman.postman-for-vscode",
        "ms-mssql.mssql",
        "GitHub.copilot"
      ]
    }
  }
}