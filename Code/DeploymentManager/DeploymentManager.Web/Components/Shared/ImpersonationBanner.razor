@using DeploymentManager.Web.Services.Impersonation
@implements IDisposable
@inject ImpersonationService Impersonation

@* Persistent global "act-as" banner. Bright amber, always on top of the content area while a
   read-only impersonation session is active. Exit restores the admin's own context. *@
@if (Impersonation.IsActive && Impersonation.CurrentSession is { } session)
{
    <div role="alert"
         class="w-full bg-amber-500 text-amber-950 px-4 py-2 flex flex-wrap items-center justify-between gap-3 shadow-md border-b border-amber-600">
        <div class="flex items-center gap-2 text-sm font-medium">
            <svg class="w-5 h-5 shrink-0 fill-current" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0Zm0 12a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm1-4a1 1 0 0 1-2 0V4a1 1 0 1 1 2 0v4Z"/>
            </svg>
            <span>
                You are currently impersonating
                <span class="font-bold">@session.TenantName</span>
                (read-only). Actions are logged.
            </span>
            <span class="hidden sm:inline text-xs text-amber-900/80">
                Expires @session.ExpiresAtUtc.ToString("HH:mm") UTC
            </span>
        </div>
        <button type="button"
                @onclick="ExitAsync"
                disabled="@_exiting"
                class="inline-flex items-center gap-1 rounded-md bg-amber-950 px-3 py-1.5 text-xs font-semibold text-amber-50 hover:bg-amber-900 disabled:opacity-60">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M11 1a1 1 0 0 1 1 1v3a1 1 0 1 1-2 0V3H4v10h6v-2a1 1 0 1 1 2 0v3a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h8Zm3.7 6.3-2-2a1 1 0 0 0-1.4 1.4l.3.3H8a1 1 0 1 0 0 2h3.6l-.3.3a1 1 0 0 0 1.4 1.4l2-2a1 1 0 0 0 0-1.4Z"/>
            </svg>
            Exit Impersonation
        </button>
    </div>
}

@code {
    private bool _exiting;

    protected override void OnInitialized() => Impersonation.OnChange += OnSessionChanged;

    private void OnSessionChanged() => InvokeAsync(StateHasChanged);

    private async Task ExitAsync()
    {
        _exiting = true;
        try
        {
            await Impersonation.ExitAsync();
        }
        finally
        {
            _exiting = false;
        }
    }

    public void Dispose() => Impersonation.OnChange -= OnSessionChanged;
}
