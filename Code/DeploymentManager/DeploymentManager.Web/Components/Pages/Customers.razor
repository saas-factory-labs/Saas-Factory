@page "/customers"
@using System.Globalization
@using AppBlueprint.AdminPortalKernel.Services
@inject IConsolidatedCustomerService CustomerService
@* Tenant impersonation ("act-as") UI is PARKED/DISABLED - see DeploymentManager.Web/Services/Impersonation.
   Read-only tenant/user viewing (the actual requirement) is provided by the kernel's guarded, rate-limited
   AdminTenants/AdminUsers pages at /apps/{slug}/admin/tenants and /apps/{slug}/admin/users. *@

<PageTitle>Customers</PageTitle>

<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-[96rem] mx-auto">

    <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-2">Customers</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
        Consolidated across every loaded SaaS app's tenant database. Each read passes the admin security guard.
    </p>

    @if (_result is not null && !_result.BillingConfigured)
    {
        <div class="bg-amber-500/20 text-amber-700 px-4 py-3 rounded-lg mb-4 text-sm">
            No billing provider is configured, so <span class="font-semibold">Paying</span> and <span class="font-semibold">MRR</span>
            are placeholders. Register an <code>ISaasBillingProvider</code> (e.g. Stripe) to populate them.
        </div>
    }

    @if (_result is not null && _result.Errors.Count > 0)
    {
        <div class="bg-red-500/20 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">
            <p class="font-semibold mb-1">Some apps could not be read:</p>
            <ul class="list-disc pl-5">
                @foreach (string error in _result.Errors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <div class="bg-white dark:bg-gray-800 shadow-xs rounded-xl">
        <div class="overflow-x-auto">
            <table class="table-auto w-full dark:text-gray-300">
                <thead class="text-xs font-semibold uppercase text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-900/20 border-t border-b border-gray-100 dark:border-gray-700/60">
                <tr>
                    <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">App</th>
                    <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Tenant</th>
                    <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Email</th>
                    <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Country</th>
                    <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Status</th>
                    <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Paying</th>
                    <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">MRR</th>
                    <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Created (UTC)</th>
                </tr>
                </thead>
                <tbody class="text-sm divide-y divide-gray-100 dark:divide-gray-700/60">
                @if (_loading)
                {
                    <tr>
                        <td colspan="8" class="px-5 py-8 text-center text-gray-500 dark:text-gray-400">Loading…</td>
                    </tr>
                }
                else if (Rows.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="px-5 py-8 text-center text-gray-500 dark:text-gray-400">No customers found across the loaded apps.</td>
                    </tr>
                }
                else
                {
                    @foreach (ConsolidatedCustomer customer in Rows)
                    {
                        <tr>
                            <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap font-medium text-gray-800 dark:text-gray-100">@customer.AppName</td>
                            <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@customer.TenantName</td>
                            <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@customer.Email</td>
                            <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@customer.Country</td>
                            <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">
                                @if (customer.IsActive)
                                {
                                    <span class="inline-flex items-center font-medium rounded-full text-center px-2.5 py-1 text-xs bg-green-500/20 text-green-700">Active</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center font-medium rounded-full text-center px-2.5 py-1 text-xs bg-red-500/20 text-red-700">Inactive</span>
                                }
                            </td>
                            <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@(customer.IsPaying ? "Yes" : "No")</td>
                            <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@customer.MonthlyRecurringRevenue.ToString("C0", CultureInfo.InvariantCulture)</td>
                            <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@customer.CreatedAt.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>

</div>

@code {
    private ConsolidatedCustomersResult? _result;
    private bool _loading = true;

    private IReadOnlyList<ConsolidatedCustomer> Rows =>
        _result is null ? [] : _result.Customers;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _result = await CustomerService.GetAllAsync();
        }
        finally
        {
            _loading = false;
        }
    }
}
