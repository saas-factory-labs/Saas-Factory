@page "/roles"
@using AppBlueprint.AdminPortalKernel.Components.Shared

<PageTitle>Global Roles &amp; Permissions</PageTitle>

<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-[96rem] mx-auto">
