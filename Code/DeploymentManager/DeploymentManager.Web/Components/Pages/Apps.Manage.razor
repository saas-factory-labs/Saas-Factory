@page "/apps/manage"
@using DeploymentManager.Web.Models
@using AppBlueprint.UiKit.Components.Shared
@using Microsoft.AspNetCore.Components.Web

<head>
    <title>Manage Apps</title>
</head>

<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-[96rem] mx-auto">

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100">Manage Apps</h1>
        <button type="button"
                class="btn bg-violet-500 hover:bg-violet-600 text-white"
                @onclick="() => _createOpen = true">
            <svg class="fill-current shrink-0 xs:hidden" width="16" height="16" viewBox="0 0 16 16">
                <path d="M15 7H9V1c0-.6-.4-1-1-1S7 .4 7 1v6H1c-.6 0-1 .4-1 1s.4 1 1 1h6v6c0 .6.4 1 1 1s1-.4 1-1V9h6c.6 0 1-.4 1-1s-.4-1-1-1z"/>
            </svg>
            <span class="max-xs:sr-only">Create App</span>
        </button>
    </div>

    <div class="bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700/60 shadow-xs rounded-xl">
        <div class="overflow-x-auto">
            <table class="table-auto w-full dark:text-gray-300">
                <thead class="text-xs font-semibold uppercase text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-900/20 border-t border-b border-gray-100 dark:border-gray-700/60">
                <tr>
                    <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Id</th>
                    <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Name</th>
                </tr>
                </thead>
                <tbody class="text-sm divide-y divide-gray-100 dark:divide-gray-700/60">
                @if (_apps.Count == 0)
                {
                    <tr>
                        <td colspan="2" class="px-5 py-8 text-center text-gray-500 dark:text-gray-400">No apps yet.</td>
                    </tr>
                }
                else
                {
                    @foreach (AppModel app in _apps)
                    {
                        <tr>
                            <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap font-medium text-gray-800 dark:text-gray-100">@app.Id</td>
                            <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@app.Name</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>

</div>

<ModalBasic @bind-IsOpen="_createOpen" Title="Create new SaaS App">
    <div class="px-5 py-4">
        <Apps_Manage_CreateDialog />
    </div>
    <div class="px-5 py-4 border-t border-gray-200 dark:border-gray-700/60">
        <div class="flex flex-wrap justify-end space-x-2">
            <button type="button"
                    class="btn-sm bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700/60 hover:border-gray-300 dark:hover:border-gray-600 text-gray-600 dark:text-gray-300"
                    @onclick="() => _createOpen = false">
                Cancel
            </button>
            <button type="button"
                    class="btn-sm bg-violet-500 hover:bg-violet-600 text-white"
                    @onclick="() => _createOpen = false">
                Create App
            </button>
        </div>
    </div>
</ModalBasic>

@code {
    private bool _createOpen;

    private List<AppModel> _apps = new();

    protected override void OnInitialized()
    {

    }
}
