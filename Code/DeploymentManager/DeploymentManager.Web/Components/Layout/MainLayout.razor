@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AdminPortalModuleRegistry AdminPortalRegistry
@using AppBlueprint.AdminPortalKernel.Modules
@using AppBlueprint.UiKit.Components.Layout
@using Microsoft.JSInterop

<MudThemeProvider @ref="_mudThemeProvider" @bind-IsDarkMode="_isDarkMode"/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<div class="flex h-[100dvh] overflow-hidden bg-gray-100 dark:bg-gray-900">

    <!-- Sidebar backdrop (mobile only) -->
    <div class="fixed inset-0 bg-gray-900/30 z-40 lg:hidden lg:z-auto transition-opacity duration-200 @(sidebarOpen ? "opacity-100" : "opacity-0 pointer-events-none")"
         aria-hidden="true"
         @onclick="() => sidebarOpen = false">
    </div>

    <!-- Sidebar -->
    <div id="sidebar"
         class="flex lg:flex flex-col absolute z-40 left-0 top-0 lg:static lg:left-auto lg:top-auto lg:translate-x-0 h-[100dvh] overflow-y-scroll lg:overflow-y-auto no-scrollbar w-64 lg:w-20 lg:sidebar-expanded:!w-64 2xl:!w-64 shrink-0 bg-white dark:bg-gray-800 p-4 transition-all duration-200 ease-in-out @(sidebarOpen ? "translate-x-0" : "-translate-x-64")">

        <!-- Logo -->
        <div class="flex justify-between mb-10 pr-3 sm:px-2">
            <a class="block" href="/">
                <svg class="fill-violet-500" xmlns="http://www.w3.org/2000/svg" width="32" height="32">
                    <path d="M31.956 14.8C31.372 6.92 25.08.628 17.2.044V5.76a9.04 9.04 0 0 0 9.04 9.04h5.716ZM14.8 26.24v5.716C6.92 31.372.63 25.08.044 17.2H5.76a9.04 9.04 0 0 1 9.04 9.04Zm11.44-9.04h5.716c-.584 7.88-6.876 14.172-14.756 14.756V26.24a9.04 9.04 0 0 1 9.04-9.04ZM.044 14.8C.63 6.92 6.92.628 14.8.044V5.76a9.04 9.04 0 0 1-9.04 9.04H.044Z"/>
                </svg>
            </a>
            <span class="hidden lg:sidebar-expanded:block 2xl:block text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase mt-2">Deployment Manager</span>
        </div>

        <!-- Navigation -->
        <div class="space-y-8">
            <div>
                <h3 class="text-xs uppercase text-gray-400 dark:text-gray-500 font-semibold pl-3">
                    <span class="hidden lg:sidebar-expanded:block 2xl:block">Navigation</span>
                </h3>
                <ul class="mt-3">

                    <SidebarMenuItem
                        Href="/"
                        Label="Dashboard"
                        IsActive="@IsDashboardActive">
                        <IconPath>
                            <path d="M5.936.278A7.983 7.983 0 0 1 8 0a8 8 0 1 1-8 8c0-.722.104-1.413.278-2.064a1 1 0 1 1 1.932.516A5.99 5.99 0 0 0 2 8a6 6 0 1 0 6-6c-.53 0-1.045.076-1.548.21A1 1 0 1 1 5.936.278Z"/>
                            <path d="M6.068 7.482A2.003 2.003 0 0 0 8 10a2 2 0 1 0-.518-3.932L3.707 2.293a1 1 0 0 0-1.414 1.414l3.775 3.775Z"/>
                        </IconPath>
                    </SidebarMenuItem>

                    <SidebarMenuGroup
                        Label="Apps"
                        IsActive="@IsAppsActive">
                        <IconPath>
                            <path d="M0 1a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V1Zm6 0a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V1Zm6 0a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V1ZM0 7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V7Zm6 0a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V7Zm6 0a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V7ZM0 13a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1v-2Zm6 0a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1v-2Zm6 0a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-2Z"/>
                        </IconPath>
                        <ChildMenuItems Context="ctx">
                            <SidebarGroupChildItem Href="/apps/manage" Label="Manage Apps" OnClick="@(() => ctx.HandleOptionClick())" />
                            <SidebarGroupChildItem Href="/apps/settings" Label="Global Settings" OnClick="@(() => ctx.HandleOptionClick())" />
                            <SidebarGroupChildItem Href="/apps/infrastructure" Label="Infrastructure" OnClick="@(() => ctx.HandleOptionClick())" />
                            <SidebarGroupChildItem Href="/apps/environments/deployments" Label="Deployments" OnClick="@(() => ctx.HandleOptionClick())" />
                            <SidebarGroupChildItem Href="/apps/configuration" Label="Configuration" OnClick="@(() => ctx.HandleOptionClick())" />
                        </ChildMenuItems>
                    </SidebarMenuGroup>

                    @if (AdminPortalRegistry.Modules.Count > 0)
                    {
                        <SidebarMenuGroup
                            Label="Admin Portals"
                            IsActive="@IsAdminPortalActive">
                            <IconPath>
                                <path d="M8 0a1 1 0 0 1 .447.106l6 3A1 1 0 0 1 15 4v4c0 3.71-2.385 6.48-6.684 7.949a1 1 0 0 1-.632 0C3.385 14.48 1 11.71 1 8V4a1 1 0 0 1 .553-.894l6-3A1 1 0 0 1 8 0Zm0 2.118L3 4.618V8c0 2.69 1.678 4.79 5 5.94 3.322-1.15 5-3.25 5-5.94V4.618l-5-2.5Z"/>
                            </IconPath>
                            <ChildMenuItems Context="ctx">
                                @foreach (IAdminPortalModule module in AdminPortalRegistry.Modules)
                                {
                                    <SidebarGroupChildItem Href="@($"/apps/{module.Slug}/admin")" Label="@module.DisplayName" OnClick="@(() => ctx.HandleOptionClick())"/>
                                }
                            </ChildMenuItems>
                        </SidebarMenuGroup>
                    }

                    <SidebarMenuItem
                        Href="/customers"
                        Label="Customers"
                        IsActive="@IsActive("/customers")">
                        <IconPath>
                            <path d="M14.14 9.585a2.5 2.5 0 0 0-3.522 3.194c-.845.63-1.87.97-2.924.971a4.979 4.979 0 0 1-1.113-.135 4.436 4.436 0 0 1-1.343 1.682 6.91 6.91 0 0 0 6.9-1.165 2.5 2.5 0 0 0 2.002-4.547ZM10.125 2.188a2.5 2.5 0 1 0 2.5 2.5 2.5 2.5 0 0 0-2.5-2.5ZM5.683 8.27a2.5 2.5 0 1 0-2.5-2.5 2.5 2.5 0 0 0 2.5 2.5ZM.125 11.875a2.5 2.5 0 1 0 2.5 2.5 2.5 2.5 0 0 0-2.5-2.5Z"/>
                        </IconPath>
                    </SidebarMenuItem>

                    <SidebarMenuItem
                        Href="/dependency-map"
                        Label="Dependency Map"
                        IsActive="@IsActive("/dependency-map")">
                        <IconPath>
                            <path d="M8 0a8 8 0 1 0 8 8A8 8 0 0 0 8 0Zm0 14.5A6.5 6.5 0 1 1 14.5 8 6.508 6.508 0 0 1 8 14.5ZM8 3a5 5 0 1 0 5 5 5 5 0 0 0-5-5Zm0 8.5A3.5 3.5 0 1 1 11.5 8 3.5 3.5 0 0 1 8 11.5ZM8 5.5A2.5 2.5 0 1 0 10.5 8 2.5 2.5 0 0 0 8 5.5Zm0 3.5A1 1 0 1 1 9 8a1 1 0 0 1-1 1Z"/>
                        </IconPath>
                    </SidebarMenuItem>

                    <SidebarMenuItem
                        Href="/cost-management"
                        Label="Cost Management"
                        IsActive="@IsActive("/cost-management")">
                        <IconPath>
                            <path d="M14.936 6.007H8.358l1.594-4.685c.3-.997-.897-1.794-1.694-.997L.284 8.3c-.598.598-.199 1.694.698 1.694H7.56l-1.594 4.685c-.3.997.897 1.794 1.694.997L15.633 7.7c.598-.598.2-1.694-.697-1.694Z"/>
                        </IconPath>
                    </SidebarMenuItem>

                    <SidebarMenuItem
                        Href="/deployment-manager/settings"
                        Label="DM Settings"
                        IsActive="@IsActive("/deployment-manager/settings")">
                        <IconPath>
                            <path d="M10.5 1a3.502 3.502 0 0 1 3.355 2.5H15a1 1 0 1 1 0 2h-1.145a3.502 3.502 0 0 1-6.71 0H1a1 1 0 0 1 0-2h6.145A3.502 3.502 0 0 1 10.5 1ZM9 4.5a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0ZM5.5 9a3.502 3.502 0 0 1 3.355 2.5H15a1 1 0 1 1 0 2H8.855a3.502 3.502 0 0 1-6.71 0H1a1 1 0 1 1 0-2h1.145A3.502 3.502 0 0 1 5.5 9ZM4 12.5a1.5 1.5 0 1 0 3 0 1.5 1.5 0 0 0-3 0Z"/>
                        </IconPath>
                    </SidebarMenuItem>

                </ul>
            </div>
        </div>
    </div>

    <!-- Content area -->
    <div class="relative flex flex-col flex-1 overflow-y-auto overflow-x-hidden bg-gray-100 dark:bg-gray-800">
        <Header SidebarOpen="@sidebarOpen" OnToggleSidebar="@(() => sidebarOpen = !sidebarOpen)"/>
        <main class="grow">
            @Body
        </main>
    </div>

</div>

<div id="blazor-error-ui" class="hidden fixed bottom-0 right-0 z-50 p-3 m-3 bg-red-500 text-white rounded-lg shadow-lg">
    An unhandled error has occurred.
    <a href="" class="reload underline ml-2">Reload</a>
    <a class="dismiss ml-2 cursor-pointer">🗙</a>
</div>

@code {
    private bool sidebarOpen;
    private bool _isDarkMode;
    private MudThemeProvider _mudThemeProvider = default!;

    private bool IsDashboardActive =>
        Navigation.Uri == Navigation.BaseUri ||
        Navigation.Uri.TrimEnd('/') == Navigation.BaseUri.TrimEnd('/');

    private bool IsAppsActive => Navigation.Uri.Contains("/apps", StringComparison.Ordinal)
                                 && !IsAdminPortalActive;

    private bool IsAdminPortalActive =>
        AdminPortalRegistry.Modules.Any(module =>
            Navigation.Uri.Contains($"/apps/{module.Slug}/admin", StringComparison.Ordinal));

    private bool IsActive(string path) =>
        Navigation.Uri.Contains(path, StringComparison.Ordinal);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await JS.InvokeAsync<bool>("themeManager.isDarkMode");
            StateHasChanged();
        }
    }
}
