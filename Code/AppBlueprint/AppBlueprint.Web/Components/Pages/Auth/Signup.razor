@page "/signup"
@layout AppBlueprint.UiKit.Components.Layout.AuthLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject NavigationManager Navigation
@inject AppBlueprint.Web.Services.FirebaseJsInterop FirebaseInterop
@inject ILogger<Signup> Logger

<main class="min-h-screen bg-slate-900">
    <div class="relative min-h-screen flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8">
        <div class="w-full max-w-md mx-auto">
            
            <!-- Header -->
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white shadow-md mb-6">
                    <svg class="w-10 h-10 text-slate-900" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                    </svg>
                </div>
                <h1 class="text-3xl font-bold text-white mb-3">
                    Create Your Account
                </h1>
                <p class="text-lg text-slate-400">
                    Get started in seconds with secure authentication
                </p>
            </div>

            <!-- Main Signup Card -->
            <div class="bg-white rounded-xl shadow-xl p-8 mb-6">
                
                <!-- Benefits List -->
                <ul class="space-y-5 mb-8">
                    <li class="flex items-start">
                        <div class="flex-shrink-0">
                            <div class="flex items-center justify-center w-6 h-6 rounded-full bg-emerald-500">
                                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                        </div>
                        <div class="ml-3">
                            <p class="text-base font-medium text-slate-900">Create your account and start immediately</p>
                        </div>
                    </li>
                    <li class="flex items-start">
                        <div class="flex-shrink-0">
                            <div class="flex items-center justify-center w-6 h-6 rounded-full bg-emerald-500">
                                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                        </div>
                        <div class="ml-3">
                            <p class="text-base font-medium text-slate-900">Customize your workspace after signing in</p>
                        </div>
                    </li>
                    <li class="flex items-start">
                        <div class="flex-shrink-0">
                            <div class="flex items-center justify-center w-6 h-6 rounded-full bg-emerald-500">
                                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                        </div>
                        <div class="ml-3">
                            <p class="text-base font-medium text-slate-900">Enterprise-grade security</p>
                        </div>
                    </li>
                    <li class="flex items-start">
                        <div class="flex-shrink-0">
                            <div class="flex items-center justify-center w-6 h-6 rounded-full bg-emerald-500">
                                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                        </div>
                        <div class="ml-3">
                            <p class="text-base font-medium text-slate-900">No credit card required</p>
                        </div>
                    </li>
                </ul>
                
                <!-- CTA Button -->
                <button
                    type="button"
                    @onclick="HandleSignup"
                    class="w-full py-3 px-6 bg-indigo-500 hover:bg-indigo-600 text-white text-base font-semibold rounded-lg transition-colors duration-150 flex items-center justify-center">
                    <span>Create Account</span>
                </button>

                @if (FirebaseInterop.IsConfigured)
                {
                    <!-- Firebase Google Sign-In -->
                    <button
                        type="button"
                        @onclick="HandleGoogleSignIn"
                        disabled="@_googleSignInBusy"
                        class="w-full mt-3 py-3 px-6 bg-white hover:bg-gray-50 text-slate-700 text-base font-semibold rounded-lg transition-colors duration-150 flex items-center justify-center border border-slate-200 shadow-sm disabled:opacity-60">
                        @if (_googleSignInBusy)
                        {
                            <svg class="animate-spin w-5 h-5 mr-2 text-slate-500" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                        }
                        else
                        {
                            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" aria-hidden="true">
                                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                            </svg>
                        }
                        <span>Continue with Google</span>
                    </button>

                    @if (!string.IsNullOrEmpty(_googleSignInError))
                    {
                        <p class="mt-2 text-sm text-red-500 text-center">@_googleSignInError</p>
                    }
                }

                <!-- Demo Mode Button -->
                <button
                    type="button"
                    @onclick="HandleDemoMode"
                    class="w-full mt-3 py-3 px-6 bg-slate-100 hover:bg-slate-200 text-slate-700 text-base font-semibold rounded-lg transition-colors duration-150 flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    <span>Try Demo Mode</span>
                </button>

                <!-- Divider -->
                <div class="relative my-6">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-slate-200"></div>
                    </div>
                    <div class="relative flex justify-center text-sm">
                        <span class="px-3 bg-white text-slate-500">
                            Secure sign up
                        </span>
                    </div>
                </div>

                <!-- Trust Badge -->
                <div class="text-center">
                    <p class="text-xs text-slate-500">
                        Protected by enterprise-grade encryption
                    </p>
                </div>
            </div>

            <!-- Footer -->
            <div class="text-center">
                <p class="text-sm text-slate-400">
                    Already have an account? 
                    <a class="font-medium text-indigo-400 hover:text-indigo-300 ml-1" href="/auth/signin">
                        Sign in
                    </a>
                </p>
            </div>

        </div>
    </div>
</main>

@code {
    private bool _googleSignInBusy;
    private string? _googleSignInError;

    private void HandleSignup()
    {
        Navigation.NavigateTo("/auth/signin", forceLoad: true);
    }

    private void HandleDemoMode()
    {
        Navigation.NavigateTo("/demo", forceLoad: true);
    }

    private async Task HandleGoogleSignIn()
    {
        _googleSignInBusy = true;
        _googleSignInError = null;
        StateHasChanged();

        try
        {
            // Step 1: Trigger the Google sign-in popup via Firebase JS SDK
            var signInResult = await FirebaseInterop.SignInWithGoogleAsync();

            if (!signInResult.Success || string.IsNullOrEmpty(signInResult.IdToken))
            {
                _googleSignInError = signInResult.Error ?? "Google sign-in failed. Please try again.";
                return;
            }

            // Step 2: Exchange the ID token for a server-side session cookie (browser fetch, not server HttpClient)
            var exchangeResult = await FirebaseInterop.ExchangeIdTokenAsync(signInResult.IdToken);

            if (!exchangeResult.Success)
            {
                _googleSignInError = exchangeResult.Error ?? "Sign-in failed on the server. Please try again.";
                return;
            }

            Logger.LogInformation("Firebase sign-in successful, redirecting to {RedirectTo}", exchangeResult.RedirectTo);
            Navigation.NavigateTo(exchangeResult.RedirectTo ?? "/dashboard", forceLoad: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error during Firebase Google sign-in");
            _googleSignInError = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _googleSignInBusy = false;
            StateHasChanged();
        }
    }
}
