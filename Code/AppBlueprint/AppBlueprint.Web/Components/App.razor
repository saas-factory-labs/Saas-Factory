<!DOCTYPE html>
<html lang="en" class="bg-gray-100 dark:bg-gray-900">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="color-scheme" content="light dark"/>
    <base href="/"/>

    <link rel="icon" type="image/png" href="favicon.png"/>
    <link rel="manifest" href="manifest.json">

    @* Cruip Tailwind CSS Theme *@
    <link rel="stylesheet" href="css/fonts.css">
    <link rel="stylesheet" href="css/flatpickr.min.css">
    <link rel="stylesheet" href="_content/AppBlueprint.UiKit/css/app.css?v=6"/>
    <link rel="stylesheet" href="AppBlueprint.Web.styles.css?v=2"/>

    <HeadOutlet/>
</head>

<body class="font-inter antialiased bg-gray-100 dark:bg-gray-900 text-gray-600 dark:text-gray-400 sidebar-expanded">
@* Runs synchronously before the rest of the page parses — no defer/async — so theme/sidebar
   state is applied before any visible content is rendered, preventing a flash of wrong theme.
   Kept as external file to avoid 'unsafe-inline' in script-src CSP. *@
<script src="js/app-init.js"></script>
<Routes @rendermode="RenderMode.InteractiveServer"/>

@* Navigation helper *@
<script src="js/navigationHelper.js"></script>

@* Cruip Tailwind Template Scripts *@
<script src="js/chart.umd.min.js"></script>
<script src="js/chartjs-adapter-date-fns.bundle.min.js"></script>
<script src="js/flatpickr.min.js"></script>
<script src="_content/AppBlueprint.UiKit/js/site.js?v=7"></script>

@* Blazor Framework - must be last *@
<script src="_framework/blazor.web.js"></script>

</body>
</html>


