<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!-- Basic Project Properties -->
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <!-- NuGet Package Configuration -->
        <Version>$(GITVERSION_SemVer)</Version>
        <PackageId>SaaS-Factory.AppBlueprint.Infrastructure.Persistence</PackageId>
        <Authors>Casper Rubæk</Authors>
        <Description>EF Core database contexts, migrations, tenant isolation and repositories for AppBlueprint</Description>
        <PackageTags>infrastructure persistence efcore postgresql multi-tenant rls migrations</PackageTags>
        <PackageProjectUrl>https://github.com/saas-factory-labs/Saas-Factory</PackageProjectUrl>
        <RepositoryUrl>https://github.com/saas-factory-labs/Saas-Factory</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageIcon>infrastructure-icon.png</PackageIcon>
    </PropertyGroup>

    <ItemGroup>
        <!-- Framework reference for IHttpContextAccessor, health checks and hosting abstractions -->
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>

    <ItemGroup>
        <!-- Entity Framework and Database -->
        <PackageReference Include="Microsoft.EntityFrameworkCore" />
        <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
        <PackageReference Include="Microsoft.EntityFrameworkCore.Design" />
        <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />

        <!-- Used by MigrationExtensions -->
        <PackageReference Include="Fluent-Regex" />

        <!-- MSBuild (explicit override for vulnerable transitive dependencies;
             pulled in via Microsoft.EntityFrameworkCore.Design -> Microsoft.CodeAnalysis.Workspaces.MSBuild,
             so these overrides must stay with whichever project owns the EF Design reference) -->
        <PackageReference Include="Microsoft.Build.Tasks.Core" />
        <PackageReference Include="Microsoft.Build.Utilities.Core" />
    </ItemGroup>

    <ItemGroup>
        <Content Update="appsettings.Development.json">
            <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\assets\icons\infrastructure-icon.png" Pack="true" PackagePath="" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\AppBlueprint.Application\AppBlueprint.Application.csproj" />
        <ProjectReference Include="..\..\AppBlueprint.Domain\AppBlueprint.Domain.csproj" />
        <ProjectReference Include="..\..\AppBlueprint.SharedKernel\AppBlueprint.SharedKernel.csproj" />
    </ItemGroup>

</Project>
