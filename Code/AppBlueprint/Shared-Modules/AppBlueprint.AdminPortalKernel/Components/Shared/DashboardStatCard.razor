@* Cruip-style stat card used on the admin dashboard. *@

<div class="col-span-12 sm:col-span-6 xl:col-span-2 2xl:col-span-2 bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700/60 shadow-xs rounded-xl p-5">
    <div class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase mb-1">@Label</div>
    <div class="text-3xl font-bold text-gray-800 dark:text-gray-100">@DisplayText</div>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public int Value { get; set; }

    /// <summary>Optional pre-formatted value (currency, percentage, …). Overrides <see cref="Value"/> when set.</summary>
    [Parameter] public string? DisplayValue { get; set; }

    private string DisplayText => DisplayValue is null
        ? Value.ToString(System.Globalization.CultureInfo.InvariantCulture)
        : DisplayValue;
}
