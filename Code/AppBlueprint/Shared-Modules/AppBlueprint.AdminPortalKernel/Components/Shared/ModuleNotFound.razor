@* Rendered when a URL references a slug with no registered admin portal module. *@

<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-[96rem] mx-auto">
    <div class="bg-white dark:bg-gray-800 shadow-xs rounded-xl p-5">
        <h1 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-2">Admin portal not found</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400">
            No admin portal module is registered for app "@Slug".
            Check that the plugin dll is present in the plugins folder and that
            <code>AdminPortal:Modules:@(Slug):ConnectionString</code> is configured.
        </p>
    </div>
</div>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
}
