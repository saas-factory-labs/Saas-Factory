@page "/apps/{AppSlug}/admin/tenants"
@inject AdminPortalModuleRegistry Registry
@inject ITenantAdminService TenantService

<PageTitle>@(_module?.DisplayName ?? AppSlug) - Tenants</PageTitle>

@if (_module is null)
{
    <ModuleNotFound Slug="@AppSlug"/>
}
else
{
    <div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-[96rem] mx-auto">
        <AdminPortalPageHeader AppSlug="@AppSlug" Title="Tenants" ModuleDisplayName="@_module.DisplayName"/>

        @if (_error is not null)
        {
            <div class="bg-red-500/20 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">@_error</div>
        }

        <div class="bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700/60 shadow-xs rounded-xl">
            <div class="px-5 py-4">
                <div class="flex items-center gap-3">
                    <input type="text" class="form-input" placeholder="Search tenant name…"
                           @bind="_searchText" @bind:event="oninput" @onkeydown="OnSearchKeyDown"/>
                    <button type="button"
                            class="btn bg-gray-900 text-gray-100 hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-800 dark:hover:bg-white"
                            @onclick="() => LoadPageAsync(1)">
                        Search
                    </button>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="table-auto w-full dark:text-gray-300">
                    <thead class="text-xs font-semibold uppercase text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-900/20 border-t border-b border-gray-100 dark:border-gray-700/60">
                    <tr>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Name</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Type</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Status</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Email</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Country</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">VAT</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Created</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><span class="sr-only">Actions</span></th>
                    </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-gray-100 dark:divide-gray-700/60">
                    @if (_page is null || _page.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="px-5 py-8 text-center text-gray-500 dark:text-gray-400">
                                @(_page is null ? "Loading…" : "No tenants found")
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (AdminTenantRecord tenant in _page.Items)
                        {
                            <tr>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap font-medium text-gray-800 dark:text-gray-100">@tenant.Name</td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@tenant.TenantType</td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">
                                    @if (tenant.IsActive)
                                    {
                                        <span class="inline-flex items-center font-medium rounded-full text-center px-2.5 py-1 text-xs bg-green-500/20 text-green-700">Active</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center font-medium rounded-full text-center px-2.5 py-1 text-xs bg-red-500/20 text-red-700">Inactive</span>
                                    }
                                </td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@(tenant.Email ?? "-")</td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@(tenant.Country ?? "-")</td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@(tenant.VatNumber ?? "-")</td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@tenant.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap w-px">
                                    <a class="text-violet-500 hover:text-violet-600 font-medium"
                                       href="/apps/@AppSlug/admin/users?tenantId=@tenant.Id">
                                        View users
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>

            @if (_page is not null && TotalPages > 1)
            {
                <div class="px-5 py-4 border-t border-gray-100 dark:border-gray-700/60">
                    <div class="flex items-center justify-between">
                        <div class="text-sm text-gray-500 dark:text-gray-400">
                            Page @_page.Page of @TotalPages (@_page.TotalCount tenants)
                        </div>
                        <div class="flex items-center gap-2">
                            <button type="button" class="btn bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700/60 hover:border-gray-300 dark:hover:border-gray-600 text-gray-800 dark:text-gray-300"
                                    disabled="@(_page.Page <= 1)" @onclick="() => LoadPageAsync(_page.Page - 1)">
                                Previous
                            </button>
                            <button type="button" class="btn bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700/60 hover:border-gray-300 dark:hover:border-gray-600 text-gray-800 dark:text-gray-300"
                                    disabled="@(_page.Page >= TotalPages)" @onclick="() => LoadPageAsync(_page.Page + 1)">
                                Next
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string AppSlug { get; set; } = string.Empty;

    private IAdminPortalModule? _module;
    private PagedResult<AdminTenantRecord>? _page;
    private string _searchText = string.Empty;
    private string? _error;

    private int TotalPages => _page is null ? 0 : (int)Math.Ceiling(_page.TotalCount / (double)_page.PageSize);

    protected override async Task OnParametersSetAsync()
    {
        Registry.TryGet(AppSlug, out _module);
        if (_module is not null)
        {
            await LoadPageAsync(1);
        }
    }

    private async Task LoadPageAsync(int page)
    {
        try
        {
            _error = null;
            _page = await TenantService.SearchAsync(AppSlug, _searchText, page, pageSize: 25);
        }
        catch (UnauthorizedAccessException)
        {
            _error = "You are not authorized to administer this app.";
        }
        catch (InvalidOperationException ex)
        {
            _error = ex.Message;
        }
    }

    private Task OnSearchKeyDown(KeyboardEventArgs args) =>
        args.Key == "Enter" ? LoadPageAsync(1) : Task.CompletedTask;
}
