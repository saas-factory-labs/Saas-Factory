@page "/apps/{AppSlug}/admin/users"
@inject AdminPortalModuleRegistry Registry
@inject IUserAdminService UserService

<PageTitle>@(_module?.DisplayName ?? AppSlug) - Users</PageTitle>

@if (_module is null)
{
    <ModuleNotFound Slug="@AppSlug"/>
}
else
{
    <div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-[96rem] mx-auto">
        <AdminPortalPageHeader AppSlug="@AppSlug" Title="Users" ModuleDisplayName="@_module.DisplayName"/>

        @if (_statusMessage is not null)
        {
            <div class="bg-green-500/20 text-green-700 px-4 py-3 rounded-lg mb-6 text-sm">@_statusMessage</div>
        }
        @if (_error is not null)
        {
            <div class="bg-red-500/20 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">@_error</div>
        }

        <div class="bg-white dark:bg-gray-800 shadow-xs rounded-xl mb-8">
            <div class="px-5 py-4">
                <div class="flex flex-wrap justify-between items-center gap-3">
                    <div class="flex items-center gap-3">
                        <input type="text" class="form-input" placeholder="Search email, username or name…"
                               @bind="_searchText" @bind:event="oninput" @onkeydown="OnSearchKeyDown"/>
                        <button type="button"
                                class="btn bg-gray-900 text-gray-100 hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-800 dark:hover:bg-white"
                                @onclick="() => LoadPageAsync(1)">
                            Search
                        </button>
                    </div>
                    @if (TenantId is not null)
                    {
                        <div class="text-sm text-gray-500 dark:text-gray-400">
                            Filtered by tenant <code>@TenantId</code>
                            <a class="text-violet-500 hover:text-violet-600 ml-2" href="/apps/@AppSlug/admin/users">Clear</a>
                        </div>
                    }
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="table-auto w-full dark:text-gray-300">
                    <thead class="text-xs font-semibold uppercase text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-900/20 border-t border-b border-gray-100 dark:border-gray-700/60">
                    <tr>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Email</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Username</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Name</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Tenant</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Status</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Last login</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap text-left">Created</th>
                        <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><span class="sr-only">Actions</span></th>
                    </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-gray-100 dark:divide-gray-700/60">
                    @if (_page is null || _page.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="px-5 py-8 text-center text-gray-500 dark:text-gray-400">
                                @(_page is null ? "Loading…" : "No users found")
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (AdminUserRecord user in _page.Items)
                        {
                            <tr class="@(_selectedUser?.Id == user.Id ? "bg-violet-50 dark:bg-violet-500/10" : "")">
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap font-medium text-gray-800 dark:text-gray-100">@user.Email</td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@user.UserName</td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@user.FirstName @user.LastName</td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><code class="text-xs">@user.TenantId</code></td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">
                                    @if (user.IsActive)
                                    {
                                        <span class="inline-flex items-center font-medium rounded-full text-center px-2.5 py-1 text-xs bg-green-500/20 text-green-700">Active</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center font-medium rounded-full text-center px-2.5 py-1 text-xs bg-red-500/20 text-red-700">Inactive</span>
                                    }
                                </td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@user.LastLogin.UtcDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap">@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap w-px">
                                    <button type="button" class="text-violet-500 hover:text-violet-600 font-medium"
                                            @onclick="() => SelectUser(user)">
                                        @(_selectedUser?.Id == user.Id ? "Close" : "View")
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>

            @if (_page is not null && TotalPages > 1)
            {
                <div class="px-5 py-4 border-t border-gray-100 dark:border-gray-700/60">
                    <div class="flex items-center justify-between">
                        <div class="text-sm text-gray-500 dark:text-gray-400">
                            Page @_page.Page of @TotalPages (@_page.TotalCount users)
                        </div>
                        <div class="flex items-center gap-2">
                            <button type="button" class="btn bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700/60 hover:border-gray-300 dark:hover:border-gray-600 text-gray-800 dark:text-gray-300"
                                    disabled="@(_page.Page <= 1)" @onclick="() => LoadPageAsync(_page.Page - 1)">
                                Previous
                            </button>
                            <button type="button" class="btn bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700/60 hover:border-gray-300 dark:hover:border-gray-600 text-gray-800 dark:text-gray-300"
                                    disabled="@(_page.Page >= TotalPages)" @onclick="() => LoadPageAsync(_page.Page + 1)">
                                Next
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (_selectedUser is not null)
        {
            <div class="bg-white dark:bg-gray-800 shadow-xs rounded-xl p-5">
                <h2 class="font-semibold text-gray-800 dark:text-gray-100 mb-4">User details</h2>
                <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2 text-sm mb-6">
                    <div><dt class="inline font-medium text-gray-500 dark:text-gray-400">Id:</dt> <dd class="inline"><code class="text-xs">@_selectedUser.Id</code></dd></div>
                    <div><dt class="inline font-medium text-gray-500 dark:text-gray-400">Email:</dt> <dd class="inline">@_selectedUser.Email</dd></div>
                    <div><dt class="inline font-medium text-gray-500 dark:text-gray-400">Username:</dt> <dd class="inline">@_selectedUser.UserName</dd></div>
                    <div><dt class="inline font-medium text-gray-500 dark:text-gray-400">Name:</dt> <dd class="inline">@_selectedUser.FirstName @_selectedUser.LastName</dd></div>
                    <div><dt class="inline font-medium text-gray-500 dark:text-gray-400">Tenant:</dt> <dd class="inline"><code class="text-xs">@_selectedUser.TenantId</code></dd></div>
                    <div><dt class="inline font-medium text-gray-500 dark:text-gray-400">External auth id:</dt> <dd class="inline"><code class="text-xs">@(_selectedUser.ExternalAuthId ?? "-")</code></dd></div>
                    <div><dt class="inline font-medium text-gray-500 dark:text-gray-400">Last login:</dt> <dd class="inline">@_selectedUser.LastLogin.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</dd></div>
                    <div><dt class="inline font-medium text-gray-500 dark:text-gray-400">Created:</dt> <dd class="inline">@_selectedUser.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd></div>
                </dl>

                <div class="border-t border-gray-100 dark:border-gray-700/60 pt-4">
                    <h3 class="text-sm font-semibold text-gray-800 dark:text-gray-100 mb-2">
                        @(_selectedUser.IsActive ? "Deactivate user" : "Activate user")
                    </h3>
                    <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">
                        A reason is required and is written to the audit log.
                    </p>
                    <textarea class="form-textarea w-full mb-3" rows="2" placeholder="Reason (required)"
                              @bind="_actionReason"></textarea>
                    <button type="button"
                            class="btn bg-gray-900 text-gray-100 hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-800 dark:hover:bg-white"
                            disabled="@(_actionBusy || string.IsNullOrWhiteSpace(_actionReason))"
                            @onclick="ToggleActiveAsync">
                        @(_actionBusy ? "Working…" : _selectedUser.IsActive ? "Deactivate" : "Activate")
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string AppSlug { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "tenantId")]
    public string? TenantId { get; set; }

    private IAdminPortalModule? _module;
    private PagedResult<AdminUserRecord>? _page;
    private AdminUserRecord? _selectedUser;
    private string _searchText = string.Empty;
    private string _actionReason = string.Empty;
    private bool _actionBusy;
    private string? _statusMessage;
    private string? _error;

    private int TotalPages => _page is null ? 0 : (int)Math.Ceiling(_page.TotalCount / (double)_page.PageSize);

    protected override async Task OnParametersSetAsync()
    {
        Registry.TryGet(AppSlug, out _module);
        if (_module is not null)
        {
            await LoadPageAsync(1);
        }
    }

    private async Task LoadPageAsync(int page)
    {
        try
        {
            _error = null;
            _page = await UserService.SearchAsync(AppSlug, new UserSearchRequest
            {
                SearchText = _searchText,
                TenantId = TenantId,
                Page = page,
                PageSize = 25
            });
        }
        catch (UnauthorizedAccessException)
        {
            _error = "You are not authorized to administer this app.";
        }
        catch (InvalidOperationException ex)
        {
            _error = ex.Message;
        }
    }

    private Task OnSearchKeyDown(KeyboardEventArgs args) =>
        args.Key == "Enter" ? LoadPageAsync(1) : Task.CompletedTask;

    private void SelectUser(AdminUserRecord user)
    {
        _selectedUser = _selectedUser?.Id == user.Id ? null : user;
        _actionReason = string.Empty;
        _statusMessage = null;
    }

    private async Task ToggleActiveAsync()
    {
        if (_selectedUser is null || string.IsNullOrWhiteSpace(_actionReason))
        {
            return;
        }

        _actionBusy = true;
        try
        {
            bool targetState = !_selectedUser.IsActive;
            bool changed = await UserService.SetActiveAsync(AppSlug, _selectedUser.Id, targetState, _actionReason);

            if (changed)
            {
                _statusMessage = $"User {_selectedUser.Email} was {(targetState ? "activated" : "deactivated")}.";
                await LoadPageAsync(_page?.Page ?? 1);
                _selectedUser = await UserService.GetAsync(AppSlug, _selectedUser.Id);
            }
            else
            {
                _error = "The user no longer exists in the app database.";
            }

            _actionReason = string.Empty;
        }
        catch (UnauthorizedAccessException)
        {
            _error = "You are not authorized to administer this app.";
        }
        catch (InvalidOperationException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _actionBusy = false;
        }
    }
}
