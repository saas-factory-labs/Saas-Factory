<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!-- Basic Project Properties -->
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <!-- Namespace is frozen to keep moved types source-compatible for consumers
             (e.g. Boligportal calls AddWebAuthentication and NormalizeLogtoOidcEndpoint) -->
        <RootNamespace>AppBlueprint.Infrastructure</RootNamespace>

        <!-- NuGet Package Configuration -->
        <Version>$(GITVERSION_SemVer)</Version>
        <PackageId>SaaS-Factory.AppBlueprint.Infrastructure.Authentication</PackageId>
        <Authors>Casper Rubæk</Authors>
        <Description>Authentication and authorization (Logto OIDC, API keys, provider abstraction) for AppBlueprint</Description>
        <PackageTags>infrastructure authentication authorization logto oidc api-keys</PackageTags>
        <PackageProjectUrl>https://github.com/saas-factory-labs/Saas-Factory</PackageProjectUrl>
        <RepositoryUrl>https://github.com/saas-factory-labs/Saas-Factory</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageIcon>infrastructure-icon.png</PackageIcon>
    </PropertyGroup>

    <ItemGroup>
        <!-- Framework reference for ASP.NET Core authentication/authorization types -->
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Logto.AspNetCore.Authentication" />
        <PackageReference Include="Microsoft.Kiota.Abstractions" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\assets\icons\infrastructure-icon.png" Pack="true" PackagePath="" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\AppBlueprint.Application\AppBlueprint.Application.csproj" />
        <!-- WebAuthenticationExtensions and ApiKeyAuthenticationHandler use ApplicationDbContext,
             B2B entities and IApiKeyRepository from the Persistence module -->
        <ProjectReference Include="..\AppBlueprint.Infrastructure.Persistence\AppBlueprint.Infrastructure.Persistence.csproj" />
    </ItemGroup>

</Project>
