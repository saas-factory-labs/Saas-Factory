<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <PackageId>SaaS-Factory.AppBlueprint.CliKit</PackageId>
    <Version Condition="'$(GITVERSION_SemVer)' != ''">$(GITVERSION_SemVer)</Version>
    <Version Condition="'$(GITVERSION_SemVer)' == ''">0.1.0-preview.1</Version>
    <NoWarn>$(NoWarn);CA1873</NoWarn>
    <Authors>SaaS Factory Labs</Authors>
    <Description>Reusable command-line infrastructure for AppBlueprint-based CLI tools.</Description>
    <PackageTags>cli command-line spectre process-runner appblueprint</PackageTags>
    <PackageProjectUrl>https://github.com/saas-factory-labs/Saas-Factory/blob/main/Code/AppBlueprint/Shared-Modules/AppBlueprint.CliKit/README.md</PackageProjectUrl>
    <RepositoryUrl>https://github.com/saas-factory-labs/Saas-Factory</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Spectre.Console" />
    <PackageReference Include="System.CommandLine" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
