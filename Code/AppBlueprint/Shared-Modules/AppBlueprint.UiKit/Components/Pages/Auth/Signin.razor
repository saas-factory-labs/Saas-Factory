@page "/signin"
@page "/login"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Configuration
@attribute [AllowAnonymous]
@inject NavigationManager Navigation
@inject IConfiguration Configuration

@code {
    protected override void OnInitialized()
    {
        string? provider = Environment.GetEnvironmentVariable("AUTHENTICATION_PROVIDER")
                        ?? Configuration["Authentication:Provider"];

        if (string.Equals(provider, "Firebase", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/signin/firebase", forceLoad: true);
        }
        else
        {
            // Default: redirect to the Logto signup flow
            Navigation.NavigateTo("/signup", forceLoad: true);
        }
    }
}
