# Build context: repo root (used by Railway and local builds from repo root)
# Single source of truth — all per-project .dockerignore files have been consolidated here.

# Build outputs
**/bin
**/obj
**/bin_verify
**/obj_verify
**/out
**/*.dll
**/*.exe
**/*.pdb

# Exception: pre-downloaded admin plugin DLLs (populated by download-admin-plugins.ps1 in CI)
!Code/DeploymentManager/plugins/*.dll
!Code/DeploymentManager/plugins/*.pdb

# Environment and secrets
**/.env
**/.env.*
**/*.local
**/appsettings.*.json
!**/appsettings.json
**/launchSettings.json
**/secrets.json
**/secrets.dev.yaml
**/values.dev.yaml
doppler.yaml

# Certificates and keys
**/*.pfx
**/*.p12
**/*.key
**/*.pem
**/*.cer
**/*.crt
**/*.cert

# Version control
**/.git
**/.gitignore
**/.gitattributes
**/.github
# Git metadata exceptions (needed for .NET Aspire source info)
!**/.gitignore
!.git/HEAD
!.git/config
!.git/packed-refs
!.git/refs/heads/**

# IDE and editor files
**/.vs
**/.vscode
**/.idea
**/*.swp
**/*.swo
**/*~
**/.DS_Store
**/*.*proj.user
**/.classpath
**/.project
**/.settings
**/.toolstarget

# Docker files
**/Dockerfile*
**/docker-compose*
**/compose*
**/.dockerignore

# DevContainer files
.devcontainer
.devcontainer.json

# Dependencies
**/node_modules
**/npm-debug.log
**/.pnp
**/.pnp.js

# Test results
**/TestResults
**/coverage
**/*.coverage
**/*.coveragexml

# Database files
**/*.db
**/*.sqlite
**/*.mdf
**/*.ldf
**/*.dbmdl
**/*.jfm

# Logs
**/*.log
**/logs/

# Cloud configs
**/.azure
**/*.publishsettings
azure.yaml

# Kubernetes
**/charts
**/azds.yaml

# Infrastructure / IaC
**/*.bicep
**/Diagrams/

# Documentation
LICENSE
README.md
**/*.md
!**/README.md

# Temporary files
**/tmp/
**/temp/
**/*.tmp
**/*.bak
